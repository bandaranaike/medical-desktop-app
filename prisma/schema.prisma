generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id             Int      @id @default(autoincrement())
  email          String?  @unique
  name           String?
  telephone      String?
  registrationNo String?
  gender         String?
  address        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
